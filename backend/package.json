{
  "name": "uber-status-tracking-backend",
  "version": "1.0.0",
  "description": "Uber Status Tracking - Backend API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "test": "npm run test:unit",
    "test:unit": "jest --forceExit --detectOpenHandles",
    "test:e2e:websocket": "node src/__tests__/websocket-test.js",
    "test:e2e:osrm": "node src/__tests__/websocket-osrm-test.js",
    "test:all": "npm run test:unit && npm run test:e2e:websocket && npm run test:e2e:osrm"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
